// shipment-service data model. Mapped to the existing snake_case tables.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShipmentRecord {
  id               String   @id @default(uuid()) @db.Uuid
  trackingNumber   String   @unique @map("tracking_number")
  fromWarehouseId  String   @map("from_warehouse_id") @db.Uuid
  toWarehouseId    String   @map("to_warehouse_id") @db.Uuid
  fromCode         String   @map("from_code")
  toCode           String   @map("to_code")
  courierId        String   @map("courier_id") @db.Uuid
  courierCode      String   @map("courier_code")
  weight           String
  status           String
  priority         String
  placed           String
  eta              String
  risk             Float    @default(0)
  items            Int      @default(1)
  transitMinutes   Int      @default(0) @map("transit_minutes")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("shipment_records")
}

model ShipmentReturn {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique
  shipmentId       String   @map("shipment_id") @db.Uuid
  shipmentTracking String   @map("shipment_tracking")
  reason           String
  initiated        String
  stage            String
  customer         String
  refund           String
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("shipment_returns")
}

model ShipmentException {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique
  shipmentId       String   @map("shipment_id") @db.Uuid
  shipmentTracking String   @map("shipment_tracking")
  kind             String
  severity         String
  age              String
  ownerName        String   @map("owner_name")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("shipment_exceptions")
}

model ShipmentTimeline {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  t          String
  label      String
  descr      String
  done       Boolean  @default(false)
  active     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("shipment_timelines")
}

model ShipmentAudit {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  t          String
  actor      String
  action     String
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("shipment_audits_v2")
}
