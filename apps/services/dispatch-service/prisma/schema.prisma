// dispatch-service data model. Mapped to existing snake_case tables.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DispatchWorkflow {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique
  type             String
  shipmentId       String   @map("shipment_id") @db.Uuid
  shipmentTracking String   @map("shipment_tracking")
  started          String
  duration         String
  status           String
  step             String
  retries          Int      @default(0)
  error            String?
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("dispatch_workflows")
}

model DispatchFailureMode {
  id        String   @id @default(uuid()) @db.Uuid
  kind      String
  count     Int      @default(0)
  trend     String   @default("flat")
  samples   Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("dispatch_failure_modes")
}

model DispatchWorkflowAudit {
  id             String   @id @default(uuid()) @db.Uuid
  workflowId     String   @map("workflow_id") @db.Uuid
  actor          String
  action         String
  reason         String?
  fromStep       String?  @map("from_step")
  toStep         String?  @map("to_step")
  fromStatus     String?  @map("from_status")
  toStatus       String?  @map("to_status")
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([workflowId, createdAt(sort: Desc)], map: "dispatch_workflow_audit_workflow_idx")
  @@map("dispatch_workflow_audit")
}
