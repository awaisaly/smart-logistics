generator dispatchClient {
  provider = "prisma-client-js"
  output   = "../src/generated/dispatch"
}

datasource db {
  provider = "postgresql"
  url      = env("DISPATCH_DATABASE_URL")
}

model DispatchWorkflow {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique
  type             String
  shipmentId       String   @map("shipment_id") @db.Uuid
  shipmentTracking String   @map("shipment_tracking")
  started          String
  duration         String
  status           String
  step             String
  retries          Int      @default(0)
  error            String?
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("dispatch_workflows")
}
