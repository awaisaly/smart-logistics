// Read-only view of the shipment_service DB. Analytics recomputes business
// metrics live from real shipment rows. Aggregates use $queryRaw against this
// client to keep the exact Postgres expressions (FILTER, to_char, split_part…).

generator shipmentClient {
  provider = "prisma-client-js"
  output   = "../src/generated/shipment"
}

datasource db {
  provider = "postgresql"
  url      = env("SHIPMENT_DATABASE_URL")
}

model ShipmentRecord {
  id             String   @id
  from           String
  to             String
  weight         String
  status         String
  priority       String
  courier        String
  placed         String
  eta            String
  risk           Float    @default(0)
  items          Int      @default(1)
  transitMinutes Int      @default(0) @map("transit_minutes")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("shipment_records")
}

model ShipmentException {
  id        String   @id
  shipment  String
  kind      String
  severity  String
  age       String
  ownerName String   @map("owner_name")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("shipment_exceptions")
}
