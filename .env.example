# ─────────────────────────────────────────────────────────────────────────────
# SmartLogistics environment template. Copy to `.env` and fill in secrets.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Global
NODE_ENV=development
LOG_LEVEL=info
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
INTERNAL_SERVICE_SECRET=change_me_internal

# Gateway
API_GATEWAY_PORT=4000

# Service ports
USER_SERVICE_PORT=4001
SHIPMENT_SERVICE_PORT=4002
WAREHOUSE_SERVICE_PORT=4003
COURIER_SERVICE_PORT=4004
DISPATCH_SERVICE_PORT=4005
TRACKING_SERVICE_PORT=4006
NOTIFICATION_SERVICE_PORT=4007
ANALYTICS_SERVICE_PORT=4008
AI_SERVICE_PORT=4009
FRONTEND_PORT=5173
# Base URL the frontend uses to reach the API gateway (exposed to the client):
VITE_API_BASE_URL=http://localhost:4000

# Postgres
# Each service owns its own database. For local (non-Docker) dev the host
# ports are fixed per service (shipment 5433, warehouse 5434, courier 5435,
# dispatch 5436, notification 5437, ai 5438, analytics 5439, user 5441), so
# do NOT set a single POSTGRES_PORT globally. Set DATABASE_URL per service
# only if you need to override the derived connection string.
POSTGRES_USER=smartlogistics
POSTGRES_PASSWORD=smartlogistics
POSTGRES_DB=smartlogistics
POSTGRES_HOST=localhost
# analytics-service reads shipment data directly:
SHIPMENT_POSTGRES_PORT=5433

# Mongo (tracking-service + warehouse docs)
MONGO_INITDB_ROOT_USERNAME=smartlogistics
MONGO_INITDB_ROOT_PASSWORD=smartlogistics
MONGO_HOST=localhost
MONGO_PORT=27018
TRACKING_MONGO_DB=tracking_service

# Redis (cache + BullMQ)
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=smart-logistics
SCHEMA_REGISTRY_URL=http://localhost:8081

# Temporal (dispatch/delivery workflows)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=smart-logistics
# Set to "false" to run the dispatch service without the in-process worker.
DISPATCH_WORKER_INPROCESS=true

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9464

# AI / LLM providers (set at least GROQ_API_KEY to enable the assistant)
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=replace_me
OPENAI_API_KEY=replace_me
# Where the ai-service reaches the gateway for tool-calls (defaults to the gateway port):
INTERNAL_API_GATEWAY_URL=http://localhost:4000
# Live-recommendations refresh cadence (min 15000ms):
SUGGESTIONS_REFRESH_MS=60000

# Vector store (provisioned; retrieval currently via live tool-calling)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=smartlogistics_ops_vectors

# Demo / auth
# Shared password for the seeded demo accounts (used by login + seed).
DEMO_PASSWORD=smartlogistics
